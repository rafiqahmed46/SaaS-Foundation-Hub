rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // NOTE: get() calls in rule evaluation do not count toward billing quota.
    // They are necessary to enforce company-level data isolation.
    function callerCompanyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
    }

    function belongsToCallerCompany(data) {
      return isSignedIn() && data.companyId == callerCompanyId();
    }

    // ── Users — own document only ─────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // ── Companies — own company only ──────────────────────────────────────────
    match /companies/{companyId} {
      allow read: if isSignedIn() && callerCompanyId() == companyId;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && callerCompanyId() == companyId;
      allow delete: if false;
    }

    // ── Settings — own company only ───────────────────────────────────────────
    match /settings/{companyId} {
      allow read, write: if isSignedIn() && callerCompanyId() == companyId;
    }

    // ── Subscriptions — own company only ─────────────────────────────────────
    match /subscriptions/{companyId} {
      allow read, write: if isSignedIn() && callerCompanyId() == companyId;
    }

    // ── Customers ─────────────────────────────────────────────────────────────
    match /customers/{docId} {
      allow read: if belongsToCallerCompany(resource.data);
      allow create: if belongsToCallerCompany(request.resource.data);
      allow update, delete: if belongsToCallerCompany(resource.data);
    }

    // ── Customer visit check-ins (subcollection) ───────────────────────────
    match /customers/{customerId}/visits/{visitId} {
      allow read: if isSignedIn()
        && belongsToCallerCompany(get(/databases/$(database)/documents/customers/$(customerId)).data);
      allow create: if isSignedIn()
        && belongsToCallerCompany(get(/databases/$(database)/documents/customers/$(customerId)).data);
      allow update, delete: if false;
    }

    // ── Invoices — also readable publicly by document ID (portal access) ──────
    match /invoices/{docId} {
      allow read: if belongsToCallerCompany(resource.data);
      allow create: if belongsToCallerCompany(request.resource.data);
      allow update, delete: if belongsToCallerCompany(resource.data);
      // Public client portal: document ID is the bearer token
      allow read: if !isSignedIn();
      // Portal may only update amountPaid and status — nothing else
      allow update: if !isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["amountPaid", "status"]);
    }

    // ── Payments ──────────────────────────────────────────────────────────────
    match /payments/{docId} {
      allow read: if belongsToCallerCompany(resource.data);
      allow create: if belongsToCallerCompany(request.resource.data);
      allow update, delete: if belongsToCallerCompany(resource.data);
    }

    // ── Quotations ────────────────────────────────────────────────────────────
    match /quotations/{docId} {
      allow read: if belongsToCallerCompany(resource.data);
      allow create: if belongsToCallerCompany(request.resource.data);
      allow update, delete: if belongsToCallerCompany(resource.data);
    }

    // ── Work Orders ───────────────────────────────────────────────────────────
    match /workOrders/{docId} {
      allow read: if belongsToCallerCompany(resource.data);
      allow create: if belongsToCallerCompany(request.resource.data);
      allow update, delete: if belongsToCallerCompany(resource.data);
    }

    // ── Assets ────────────────────────────────────────────────────────────────
    match /assets/{docId} {
      allow read: if belongsToCallerCompany(resource.data);
      allow create: if belongsToCallerCompany(request.resource.data);
      allow update, delete: if belongsToCallerCompany(resource.data);
    }

    // ── Contracts ─────────────────────────────────────────────────────────────
    match /contracts/{docId} {
      allow read: if belongsToCallerCompany(resource.data);
      allow create: if belongsToCallerCompany(request.resource.data);
      allow update, delete: if belongsToCallerCompany(resource.data);
    }

    // ── Tasks ─────────────────────────────────────────────────────────────────
    match /tasks/{docId} {
      allow read: if belongsToCallerCompany(resource.data);
      allow create: if belongsToCallerCompany(request.resource.data);
      allow update, delete: if belongsToCallerCompany(resource.data);
    }

    // ── Technicians ───────────────────────────────────────────────────────────
    match /technicians/{docId} {
      allow read: if belongsToCallerCompany(resource.data);
      allow create: if belongsToCallerCompany(request.resource.data);
      allow update, delete: if belongsToCallerCompany(resource.data);
    }

    // ── Transactions ──────────────────────────────────────────────────────────
    match /transactions/{docId} {
      allow read: if belongsToCallerCompany(resource.data);
      allow create: if belongsToCallerCompany(request.resource.data);
      allow update, delete: if belongsToCallerCompany(resource.data);
    }

    // ── Team Invites ──────────────────────────────────────────────────────────
    match /teamInvites/{docId} {
      allow read: if belongsToCallerCompany(resource.data);
      allow create: if belongsToCallerCompany(request.resource.data);
      allow update, delete: if belongsToCallerCompany(resource.data);
    }

    // ── Admin config — public read (pricing/promo), authenticated write ───────
    match /adminConfig/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ── Super-admin wildcard — allows designated UIDs to read all collections ─
    // UIDs are stored in adminConfig/superAdmins.uids (array).
    function isSuperAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/adminConfig/superAdmins)
        && get(/databases/$(database)/documents/adminConfig/superAdmins).data.uids.hasAny([request.auth.uid]);
    }
    match /{collection}/{document=**} {
      allow read: if isSuperAdmin();
    }

    // ── Feedback — public write (client portal), authenticated read ───────────
    match /feedback/{docId} {
      allow create: if true;
      allow read: if isSignedIn();
      allow update, delete: if false;
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

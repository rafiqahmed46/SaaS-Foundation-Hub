rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper ────────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // ── Users — own document only ─────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // ── Companies — authenticated users only ─────────────────────────────────
    match /companies/{companyId} {
      allow read, write: if isSignedIn();
    }

    // ── Settings — authenticated users only ──────────────────────────────────
    match /settings/{companyId} {
      allow read, write: if isSignedIn();
    }

    // ── All business collections — authenticated users only ──────────────────
    match /customers/{docId} {
      allow read, write: if isSignedIn();
    }

    match /invoices/{docId} {
      // Authenticated users: full access
      allow read, write: if isSignedIn();
      // Public (client portal): read-only by invoice ID — URL is the token
      allow read: if true;
      // Public can only update amountPaid and status (partial payment from portal)
      allow update: if !isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["amountPaid", "status"]);
    }

    match /payments/{docId} {
      allow read, write: if isSignedIn();
    }

    match /quotations/{docId} {
      allow read, write: if isSignedIn();
    }

    match /workOrders/{docId} {
      allow read, write: if isSignedIn();
    }

    match /assets/{docId} {
      allow read, write: if isSignedIn();
    }

    match /contracts/{docId} {
      allow read, write: if isSignedIn();
    }

    match /tasks/{docId} {
      allow read, write: if isSignedIn();
    }

    match /technicians/{docId} {
      allow read, write: if isSignedIn();
    }

    match /transactions/{docId} {
      allow read, write: if isSignedIn();
    }

    match /teamInvites/{docId} {
      allow read, write: if isSignedIn();
    }

    // ── Feedback — public write (from client portal), authenticated read ──────
    match /feedback/{docId} {
      allow create: if true;
      allow read: if isSignedIn();
      allow update, delete: if false;
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
